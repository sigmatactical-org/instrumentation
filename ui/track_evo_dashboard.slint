import { SigmaTheme } from "theme.slint";
import { HorizontalTach } from "widgets/horizontal_tach.slint";

component EvoBar inherits Rectangle {
    in property <string> name;
    in property <color> bar-color;
    in property <bool> active;

    height: 32px;
    background: root.active ? root.bar-color.with-alpha(0.35) : #101010;
    border-width: 1px;
    border-color: root.active ? root.bar-color : #222222;

    Text {
        width: 100%;
        height: 100%;
        text: root.name;
        font-size: 12px;
        font-weight: 700;
        color: root.active ? #ffffff : #333333;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component TrackEvoDashboard inherits Rectangle {
    in property <float> rpm: 12500;
    in property <int> speed: 210;
    in property <int> gear: 6;
    in property <string> riding-mode: "Race A";
    in property <string> lap-time: "1:42.387";
    in property <int> lap-count: 7;
    in property <bool> dtc-active: false;
    in property <bool> dwc-active: false;
    in property <bool> ebc-active: false;
    in property <bool> dsc-active: false;

    background: SigmaTheme.bg;

    VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 18px;
        spacing: 0px;

        HorizontalTach {
            width: 100%;
            rpm: root.rpm;
        }

        HorizontalLayout {
            vertical-stretch: 1;

            VerticalLayout {
                width: 320px;
                padding-top: 28px;
                spacing: 8px;
                Text {
                    text: root.lap-time;
                    font-size: 56px;
                    font-weight: 300;
                    color: SigmaTheme.text-primary;
                }
                Text {
                    text: "LAP " + root.lap-count + "   " + root.speed + " km/h";
                    font-size: 16px;
                    color: SigmaTheme.text-dim;
                }
                Text {
                    text: root.riding-mode;
                    font-size: 18px;
                    font-weight: 600;
                    color: SigmaTheme.sigma-red;
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                Text {
                    text: root.gear;
                    font-size: 220px;
                    font-weight: 600;
                    color: SigmaTheme.text-primary;
                    horizontal-alignment: center;
                }
            }

            VerticalLayout {
                width: 140px;
                padding-top: 40px;
                spacing: 8px;
                EvoBar { name: "DTC"; bar-color: #00cc44; active: root.dtc-active; }
                EvoBar { name: "DWC"; bar-color: #0088ff; active: root.dwc-active; }
                EvoBar { name: "EBC"; bar-color: #e87800; active: root.ebc-active; }
                EvoBar { name: "DSC"; bar-color: #bb44ff; active: root.dsc-active; }
            }
        }
    }
}
