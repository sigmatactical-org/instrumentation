import { SigmaTheme } from "theme.slint";
import { HorizontalTach } from "widgets/horizontal_tach.slint";

component SplitRow inherits Rectangle {
    in property <string> tag;
    in property <string> value;
    in property <color> tag-color;

    height: 28px;
    HorizontalLayout {
        spacing: 16px;
        Text {
            text: root.tag;
            font-size: 14px;
            font-weight: 600;
            color: root.tag-color;
            vertical-alignment: center;
            width: 28px;
        }
        Text {
            text: root.value;
            font-size: 20px;
            font-weight: 400;
            color: SigmaTheme.text-primary;
            vertical-alignment: center;
        }
    }
}

component ELevel inherits Rectangle {
    in property <string> name;
    in property <int> level;

    VerticalLayout {
        spacing: 2px;
        Text {
            text: root.name;
            font-size: 10px;
            color: SigmaTheme.text-dim;
            horizontal-alignment: center;
        }
        Text {
            text: root.level;
            font-size: 18px;
            font-weight: 600;
            color: SigmaTheme.text-primary;
            horizontal-alignment: center;
        }
    }
}

export component TrackDashboard inherits Rectangle {
    in property <float> rpm: 11000;
    in property <int> speed: 198;
    in property <int> gear: 5;
    in property <string> riding-mode: "Race A";
    in property <int> coolant-c: 98;
    in property <string> clock: "14:32";
    in property <string> lap-time: "1:42.387";
    in property <string> best-lap: "1:41.902";
    in property <string> last-lap: "1:42.891";
    in property <int> lap-count: 7;
    in property <int> dtc: 1;
    in property <int> dwc: 1;
    in property <int> ebc: 1;
    in property <int> dsc: 1;
    in property <string> split-t1: "+0.12";
    in property <string> split-t2: "-0.08";
    in property <string> split-t3: "+0.21";

    background: SigmaTheme.bg;

    VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 18px;
        spacing: 0px;

        HorizontalTach {
            width: 100%;
            rpm: root.rpm;
        }

        Rectangle { height: 8px; }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            VerticalLayout {
                width: 340px;
                padding-top: 20px;
                spacing: 6px;

                Text {
                    text: "LAP " + root.lap-count;
                    font-size: 13px;
                    color: SigmaTheme.text-dim;
                }
                Text {
                    text: root.lap-time;
                    font-size: 64px;
                    font-weight: 300;
                    color: SigmaTheme.text-primary;
                }
                HorizontalLayout {
                    spacing: 28px;
                    Text {
                        text: "B " + root.best-lap;
                        font-size: 16px;
                        color: #6a6a6a;
                    }
                    Text {
                        text: "L " + root.last-lap;
                        font-size: 16px;
                        color: #6a6a6a;
                    }
                }
                Text {
                    text: root.speed + " km/h";
                    font-size: 28px;
                    font-weight: 300;
                    color: SigmaTheme.text-secondary;
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;

                Text {
                    text: root.gear;
                    font-size: 200px;
                    font-weight: 600;
                    color: SigmaTheme.text-primary;
                    horizontal-alignment: center;
                }
            }

            VerticalLayout {
                width: 300px;
                padding-top: 24px;
                padding-right: 12px;
                spacing: 14px;
                alignment: start;

                SplitRow { tag: "T1"; value: root.split-t1; tag-color: #ffffff; }
                SplitRow { tag: "T2"; value: root.split-t2; tag-color: #888888; }
                SplitRow { tag: "T3"; value: root.split-t3; tag-color: #e87800; }

                Rectangle { height: 12px; }

                HorizontalLayout {
                    spacing: 18px;
                    ELevel { name: "DTC"; level: root.dtc; }
                    ELevel { name: "DWC"; level: root.dwc; }
                    ELevel { name: "EBC"; level: root.ebc; }
                    ELevel { name: "DSC"; level: root.dsc; }
                }

                Rectangle { vertical-stretch: 1; }

                Text {
                    text: root.riding-mode;
                    font-size: 20px;
                    font-weight: 600;
                    color: SigmaTheme.sigma-red;
                    horizontal-alignment: right;
                }
                Text {
                    text: root.coolant-c + " °C   " + root.clock;
                    font-size: 16px;
                    color: SigmaTheme.text-dim;
                    horizontal-alignment: right;
                }
            }
        }
    }
}
