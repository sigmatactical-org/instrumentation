import { SigmaTheme } from "../theme.slint";

component MenuRow inherits Rectangle {
    in property <string> label;
    in property <string> detail: "";
    in property <string> sub: "";
    in property <bool> active: false;
    in property <bool> show-chevron: false;

    height: sub != "" ? 56px : 42px;
    background: root.active ? SigmaTheme.menu-active : transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 10px;

        Text {
            text: root.show-chevron && root.active ? "▸" : " ";
            font-size: 12px;
            color: SigmaTheme.menu-chevron;
            vertical-alignment: center;
            width: 12px;
        }

        VerticalLayout {
            alignment: center;
            spacing: 1px;

            Text {
                text: root.label;
                font-size: 15px;
                font-weight: root.active ? 600 : 400;
                color: root.active ? SigmaTheme.text-primary : SigmaTheme.text-secondary;
            }
            if root.detail != "": Text {
                text: root.detail;
                font-size: 13px;
                color: SigmaTheme.text-secondary;
                overflow: elide;
            }
            if root.sub != "": Text {
                text: root.sub;
                font-size: 12px;
                color: SigmaTheme.text-dim;
                overflow: elide;
            }
        }
    }
}

export component LeftMenu inherits Rectangle {
    in property <string> selected: "player";
    in property <string> trip-label: "Trip 1";
    in property <string> trip-value: "12407 km";
    in property <string> player-title: "Red Shift";
    in property <string> player-artist: "Engine Room";

    width: 100%;
    background: transparent;

    VerticalLayout {
        padding-left: 28px;
        padding-top: 36px;
        padding-right: 16px;
        spacing: 0px;

        MenuRow {
            label: root.trip-label;
            detail: root.trip-value;
            active: root.selected == "trip";
        }
        MenuRow {
            label: "Player";
            detail: root.player-title;
            sub: root.player-artist;
            active: root.selected == "player";
            show-chevron: true;
        }
        MenuRow {
            label: "Settings";
            active: root.selected == "settings";
        }
        MenuRow {
            label: "Telephone";
            active: root.selected == "phone";
        }
        MenuRow {
            label: "Heated grips";
            detail: "Off";
            active: root.selected == "grips";
        }
    }
}
