import { SigmaTheme } from "../theme.slint";

export enum AidIcon { BracketUp, Circle, BracketDown }

component AidIconWidget inherits Rectangle {
    in property <AidIcon> icon-type: AidIcon.Circle;

    width: 14px;
    height: 18px;
    background: transparent;

    if root.icon-type == AidIcon.BracketUp || root.icon-type == AidIcon.BracketDown: Path {
        width: 100%; height: 100%;
        viewbox-width: 14; viewbox-height: 18;
        MoveTo { x: 10; y: 4; }
        LineTo { x: 10; y: 16; }
        stroke: SigmaTheme.ink-muted; stroke-width: 1px;
    }

    if root.icon-type == AidIcon.BracketUp: Text {
        x: 6px; y: 0px;
        text: "^";
        font-size: 8px;
        color: SigmaTheme.ink;
    }

    if root.icon-type == AidIcon.BracketDown: Text {
        x: 6px; y: 10px;
        text: "v";
        font-size: 8px;
        color: SigmaTheme.ink;
    }

    if root.icon-type == AidIcon.Circle: Path {
        width: 100%; height: 100%;
        viewbox-width: 14; viewbox-height: 18;
        MoveTo { x: 10; y: 9; }
        ArcTo {
            x: 10; y: 9;
            radius-x: 4; radius-y: 4;
            sweep: true; large-arc: true;
        }
        stroke: SigmaTheme.ink; stroke-width: 1px;
    }
}

component AidRow inherits Rectangle {
    in property <string> name;
    in property <int> level;
    in property <AidIcon> icon-type: AidIcon.Circle;

    height: 18px;
    background: transparent;

    HorizontalLayout {
        spacing: 5px;
        alignment: end;

        Text {
            text: root.name;
            font-size: 10px;
            font-weight: 700;
            font-italic: true;
            color: SigmaTheme.ink;
            vertical-alignment: center;
        }
        Text {
            text: root.level;
            font-size: 12px;
            font-weight: 800;
            font-italic: true;
            color: SigmaTheme.ink;
            vertical-alignment: center;
        }
        AidIconWidget {
            icon-type: root.icon-type;
        }
    }
}

export component ElectronicsPanel inherits Rectangle {
    in property <int> dtc: 3;
    in property <int> dwc: 3;
    in property <int> dsc: 2;

    width: 96px;
    background: transparent;

    VerticalLayout {
        spacing: 2px;
        alignment: end;

        AidRow { name: "DTC"; level: root.dtc; icon-type: AidIcon.BracketUp; }
        AidRow { name: "DWC"; level: root.dwc; icon-type: AidIcon.Circle; }
        AidRow { name: "DSC"; level: root.dsc; icon-type: AidIcon.BracketDown; }
    }
}
