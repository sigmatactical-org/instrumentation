import { SigmaTheme } from "../theme.slint";

component DataRow inherits Rectangle {
    in property <string> label;
    in property <bool> warn: false;
    in property <bool> accent: false;

    height: 32px;
    background: transparent;

    Text {
        width: 100%;
        text: root.label;
        font-size: 20px;
        font-weight: 400;
        color:
            root.accent ? SigmaTheme.shift-led :
            root.warn ? SigmaTheme.shift-orange :
            SigmaTheme.text-secondary;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

export component RightData inherits Rectangle {
    in property <int> speed: 0;
    in property <string> clock: "14:32";
    in property <int> coolant-c: 88;
    in property <string> riding-mode: "Sport";
    in property <bool> cruise-active: false;

    width: 100%;
    background: transparent;

    VerticalLayout {
        padding-top: 48px;
        padding-right: 36px;
        spacing: 0px;
        alignment: start;

        Text {
            text: root.speed;
            font-size: 96px;
            font-weight: 300;
            color: SigmaTheme.text-primary;
            horizontal-alignment: right;
        }
        Text {
            text: "km/h";
            font-size: 18px;
            font-weight: 400;
            color: SigmaTheme.text-secondary;
            horizontal-alignment: right;
        }

        Rectangle { height: 28px; }

        DataRow { label: root.clock; }
        DataRow {
            label: root.coolant-c + " °C";
            warn: root.coolant-c > 100;
        }
        if root.cruise-active: DataRow { label: "CRUISE"; accent: true; }

        Rectangle { vertical-stretch: 1; }

        Text {
            text: root.riding-mode;
            font-size: 22px;
            font-weight: 600;
            color: SigmaTheme.sigma-red;
            horizontal-alignment: right;
        }
    }
}
