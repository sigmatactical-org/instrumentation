import { SigmaTheme } from "../theme.slint";

export component SportTab inherits Rectangle {
    in property <string> mode: "SPORT";

    width: 92px;
    height: 26px;
    background: transparent;

    Path {
        width: 100%; height: 100%;
        viewbox-width: 92; viewbox-height: 26;
        MoveTo { x: 0; y: 2; }
        LineTo { x: 74; y: 2; }
        LineTo { x: 92; y: 13; }
        stroke: SigmaTheme.ink; stroke-width: 1px;
    }

    Path {
        width: 100%; height: 100%;
        viewbox-width: 92; viewbox-height: 26;
        MoveTo { x: 0; y: 24; }
        LineTo { x: 74; y: 24; }
        LineTo { x: 92; y: 13; }
        stroke: SigmaTheme.ink; stroke-width: 1px;
    }

    Path {
        width: 100%; height: 100%;
        viewbox-width: 92; viewbox-height: 26;
        MoveTo { x: 0; y: 2; }
        LineTo { x: 0; y: 24; }
        stroke: SigmaTheme.ink; stroke-width: 1px;
    }

    Text {
        x: 10px;
        y: 5px;
        text: root.mode;
        font-size: 12px;
        font-weight: 800;
        font-italic: true;
        color: SigmaTheme.ink;
        letter-spacing: 0.5px;
    }
}
