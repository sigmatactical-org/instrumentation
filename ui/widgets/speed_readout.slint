import { SigmaTheme, SigmaTone } from "../theme.slint";

export component SpeedReadout inherits Rectangle {
    in property <string> d-hundreds;
    in property <string> d-tens;
    in property <string> d-ones;
    in property <bool> hot: false;

    property <length> cell: 50px;
    property <color> tint: root.hot ? SigmaTheme.accent-red-dim : SigmaTheme.dial-value;
    opacity: SigmaTone.speed-opacity;

    width: 3 * cell + 52px;
    height: 98px;
    clip: false;

    Rectangle {
        x: 0; y: 0; width: cell; height: 86px;
        clip: false;
        Text {
            x: (parent.width - self.preferred-width) / 2;
            y: (parent.height - self.preferred-height) / 2;
            text: root.d-hundreds;
            color: tint;
            font-size: 72px;
            font-weight: 700;
        }
    }
    Rectangle {
        x: cell; y: 0; width: cell; height: 86px;
        clip: false;
        Text {
            x: (parent.width - self.preferred-width) / 2;
            y: (parent.height - self.preferred-height) / 2;
            text: root.d-tens;
            color: tint;
            font-size: 72px;
            font-weight: 700;
        }
    }
    Rectangle {
        x: 2 * cell; y: 0; width: cell; height: 86px;
        clip: false;
        Text {
            x: (parent.width - self.preferred-width) / 2;
            y: (parent.height - self.preferred-height) / 2;
            text: root.d-ones;
            color: tint;
            font-size: 72px;
            font-weight: 700;
        }
    }

    Text {
        x: 3 * cell + 8px; y: 48px;
        text: "km/h";
        color: root.hot ? SigmaTheme.accent-red-dim : SigmaTheme.dial-caption;
        font-size: 10px;
        font-weight: 600;
    }
}
