// Matte-black instrument cluster palette
export global SigmaTheme {
    out property <color> bg: #141414;
    out property <color> tft: #000000;
    out property <color> ink: #eeeeee;
    out property <color> ink-soft: #cccccc;
    out property <color> ink-muted: #888888;
    out property <color> ink-faint: #555555;
    // Single accent red — needle, trail, redline zone, high speed
    out property <color> accent-red: #b85858;
    out property <color> accent-red-dim: #7a3838;
    out property <color> side-stand-bg: #2a2a2a;
    out property <color> side-stand-fg: #dddddd;
    out property <color> temp-track: #333333;
    out property <color> temp-fill: #777777;
}
