import { SigmaTheme } from "../theme.slint";

// Banner when vehicle telemetry is missing — must not wash out the dial.
export component TelemetryOverlay inherits Rectangle {
    in property <bool> live: true;

    visible: !root.live;
    width: 100%;
    height: 36px;
    y: 0;
    background: #000000cc;

    Text {
        width: 100%;
        height: 100%;
        text: "NO VEHICLE DATA";
        color: #c86868;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 2px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
